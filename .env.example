DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
# Optional: a DIRECT (non-pooled) connection used only for migrations. Set this
# when DATABASE_URL is a pooled/PgBouncer URL (e.g. Neon's `-pooler` host). If
# left blank, migrations use DATABASE_URL.
DIRECT_URL=""
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Google OAuth ("Sign in with Google"). When BOTH are set, the Google
# button appears on the login page. Create an OAuth client at
# https://console.cloud.google.com → APIs & Services → Credentials → OAuth client
# ID (Web application), with authorized redirect URI:
#   <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional: email provider for password-reset links (Resend).
# If RESEND_API_KEY is unset, the reset link is logged to the server console
# instead of being emailed - the flow still works, you just read it from the logs.
RESEND_API_KEY=""
RESEND_FROM="onboarding@resend.dev"
